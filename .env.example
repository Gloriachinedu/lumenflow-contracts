# LumenFlow environment configuration
# Copy this file to .env.local, .env.testnet, or .env.mainnet and fill in the values.
# Never commit files other than .env.example to version control.

# Network name passed to the Stellar CLI (local | testnet | mainnet)
NETWORK=testnet

# RPC endpoint for the target network
# local:   http://localhost:8000/soroban/rpc
# testnet: https://soroban-testnet.stellar.org
# mainnet: https://soroban.stellar.org
RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase
# local:   "Standalone Network ; February 2017"
# testnet: "Test SDF Network ; September 2015"
# mainnet: "Public Global Stellar Network ; September 2015"
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Stellar secret key used to pay deployment fees
SOURCE_ACCOUNT=

# Deployed contract ID (populated after first deploy)
CONTRACT_ID=

# Admin address (Stellar public key)
ADMIN_ADDRESS=
