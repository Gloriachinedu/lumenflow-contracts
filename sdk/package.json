{
  "name": "@lumenflow/sdk",
  "version": "0.2.0",
  "description": "LumenFlow TypeScript SDK — Node.js wrapper for the LumenFlow Soroban contract",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:integration": "jest --testPathPattern=integration"
  },
  "keywords": ["stellar", "soroban", "lumenflow", "payments", "sdk"],
  "author": "LumenFlow Contributors",
  "license": "MIT",
  "dependencies": {
    "@stellar/stellar-sdk": "^12.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"]
  }
}
